[module/pulseaudio]
type = internal/pulseaudio

use-ui-max = false
interval = 5
format-volume = <label-volume>
format-muted = <label-muted>

label-volume = %{T1}%{T-} %{T2}%percentage%%%{T-}
label-volume-foreground = ${colors.green}

label-muted = %{T1}婢%{T-}
label-muted-foreground = ${colors.red}

click-right = pavucontrol &
