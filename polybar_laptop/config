[colors]
grey = ${xrdb:color6}
yellow = ${xrdb:color1}
white = ${xrdb:color5}
green = ${xrdb:color16}
background = #32302f
background-alt = #3C3836
foreground = ${xrdb:foreground}
foreground-alt = #EBDBB2
primary = ${xrdb:color0}
secondary = ${xrdb.color15}
alert = ${xrdb:color15}

[bar/laptop]
override-redirect = false
width = 100%
height = 29

fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = ${colors.white}

padding-left = 0
padding-right = 1

module-margin = 0

font-0 = Iosevka:weight=medium:pixelsize=8;2
font-1 = Iosevka:weight=medium:pixelsize=6;1
font-2 = Symbols Nerd Font:size=8

modules-left = powermenu bspwm sps xkeyboard
modules-center = title
modules-right = backlight sps pulseaudio sps cpu sps memory sps temperature sps battery_one sps battery_two sps date

spacing = 0

dim-value = 1.0

wm-name = bspwm
wm-restack = bspwm

tray-position = right
tray-detached = false
tray-maxsize = 16
tray-padding = 2
tray-scale = 1

dpi-x = 133
dpi-y = 133
; cursor-click = pointer
; cursor-scroll = ns-resize

[module/sps]
type = custom/text
content = " "
content-padding = 0

[module/title]
type = internal/xwindow
format = <label>
format-foreground = ${colors.primary}

label = %title%
label-maxlen = 65
label-empty = %{T2}Oberg Bspwm%{T-}
label-empty-foreground = ${colors.grey}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-foreground = ${colors.primary}

label-layout = %layout%

[module/bspwm]
type = internal/bspwm

pin-workspaces = true
inline-mode = false
enable-click = true
enable-scroll = true
reverse-scroll = false
fuzzy-match = true

format = <label-state> <label-mode>

label-focused = %name%
label-focused-background = ${colors.primary}
label-focused-padding = 1

label-occupied = %name%
label-occupied-padding = 1

label-urgent = %name%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = %name%
label-empty-foreground = ${colors.grey}
label-empty-padding = 1

[module/backlight]
type = internal/backlight

card = intel_backlight
enable-scroll = true

format = <label>
format-foreground = ${colors.primary}

label = %{T2}ÔÉę %percentage%%%{T-}

[module/cpu]
type = internal/cpu
interval = 0.5

format-foreground = ${colors.primary}
format = <label>

label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 0.5
format-foreground = ${colors.primary}
format = <label>

label = %percentage_used%%

[module/date]
type = internal/date
interval = 1.0

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format = <label>
format-foreground = ${colors.primary}

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

use-ui-max = false
interval = 5
format-volume = <label-volume>
format-muted = <label-muted>

label-volume = %{T1}ÔÄ¶%{T-} %{T2}%percentage%%%{T-}
label-volume-foreground = ${colors.primary}

label-muted = %{T1}Ô™Ä%{T-}
label-muted-foreground = ${colors.grey}

click-right = pavucontrol &

[module/battery_one]
type = internal/battery

full-at = 99
battery = BAT0
adapter = ADP1
poll-interval = 5
format-charging = <label-charging>
format-discharging = <label-discharging>

label-charging = %{T2}ÔĖÉ%{T-} %{T2}%percentage%%%{T-}
label-charging-foreground = ${colors.green}

label-discharging = %{T1}ÔČĀ%{T-} %{T2}%percentage%%%{T-}
label-discharging-foreground = ${colors.alert}

label-full = %{T1}ÔČÄ%{T-} %{T2}%{T-}
label-full-foreground = ${colors.primary}

[module/battery_two]
type = internal/battery

full-at = 99
battery = BAT1
adapter = ADP1
poll-interval = 5
format-charging = <label-charging>
format-discharging = <label-discharging>

label-charging = %{T2}ÔĖÉ%{T-} %{T2}%percentage%%%{T-}
label-charging-foreground = ${colors.green}

label-discharging = %{T1}ÔČĀ%{T-} %{T2}%percentage%%%{T-}
label-discharging-foreground = ${colors.alert}

label-full = %{T1}ÔČÄ%{T-} %{T2}%{T-}
label-full-foreground = ${colors.primary}

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format-foreground = ${colors.primary}
format-prefix = "Óąč "
format = <label>

label = %temperature-c%


[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[module/powermenu]
type = custom/text
content = "‚ŹĽ"
click-left = ~/.config/rofi/powermenu.sh
content-background = ${colors.alert}
content-foreground = ${colors.white}
content-padding = 1
margin-right = 0

[global/wm]
margin-top = 5
margin-bottom = 5

; vim:ft=dosini
