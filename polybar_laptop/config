[colors]
darkgray = ${xrdb:color8}
orange = ${xrdb:color3}
yellow = ${xrdb:color1}
white = ${xrdb:color5}
green = ${xrdb:color16}
background = ${xrdb:background}
background-alt = #4e4e4e
foreground = ${xrdb:color9}
foreground-alt = ${xrdb:foreground}
primary = ${xrdb:color9}
secondary = ${colors.orange}
alert = ${xrdb:color0}

[bar/laptop]
override-redirect = false
width = 100%
height = 29

fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = #FFF

padding-left = 0
padding-right = 1

module-margin = 0

font-0 = Iosevka:weight=medium:pixelsize=8;2
font-1 = Iosevka:weight=medium:pixelsize=6;1
font-2 = Iosevka:weight=bold:pixelsize=10;0

modules-left = powermenu bspwm sps xkeyboard
modules-center = title
modules-right = backlight sps pulseaudio sps cpu sps memory sps wlan sps temperature sps battery_one sps battery_two sps date

spacing = 0

dim-value = 1.0

wm-name = bspwm
wm-restack = bspwm

tray-position = right
tray-detached = false
tray-maxsize = 16
tray-padding = 2
tray-scale = 1

dpi-x = 133
dpi-y = 133
; cursor-click = pointer
; cursor-scroll = ns-resize

[module/sps]
type = custom/text
content = " "
content-padding = 0

[module/title]
type = internal/xwindow
format = <label>
format-foreground = ${colors.color9}

label = %title%
label-maxlen = 65
label-empty = %{T2}Oberg Bspwm%{T-}
label-empty-forground = ${colors.color5}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "ÓČĮ"
format-prefix-foreground = ${colors.foreground-alt}
format-prefix-underline = ${colors.secondary}

label-layout = %layout%
label-layout-underline = ${colors.secondary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}
label-indicator-underline = ${colors.secondary}

[module/bspwm]
type = internal/bspwm

pin-workspaces = true
inline-mode = false
enable-click = true
enable-scroll = true
reverse-scroll = false
fuzzy-match = true

format = <label-state> <label-mode>

label-focused = %name%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 1

label-occupied = %name%
label-occupied-padding = 1

label-urgent = %name%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = %name%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 1

label-separator =
label-separator-padding= = 0
label-separator-foreground = ${colors.background-alt}

[module/backlight]
type = internal/backlight

card = intel_backlight
enable-scroll = true

format = <label>
format-foreground = ${colors.color1}

label = %{T2}ÔÉę %percentage%%%{T-}

[module/cpu]
type = internal/cpu
interval = 0.5

label = %percentage:2%%
label-foreground= ${xrdb:color1}

[module/memory]
type = internal/memory
interval = 0.5
format = <label>

label = %percentage_used%%
label-foreground= ${xrdb:color2}

[module/wlan]
type = internal/network
interface = wlan0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
format-connected-underline = ${xrdb:color3}
label-connected = %essid%

format-disconnected =

ramp-signal-0 = Óąė
ramp-signal-1 = Óąô
ramp-signal-2 = Óąö
ramp-signal-3 = Óąö
ramp-signal-4 = Óąö
ramp-signal-foreground = ${colors.foreground-alt}

[module/eth]
type = internal/network
interface = enp3s0
interval = 3.0

format-connected-underline = ${xrdb:color3}
format-connected-prefix = "ÓÜú"
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected =

[module/date]
type = internal/date
interval = 1.0

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = ÓÄĖ
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${xrdb:color4}

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

use-ui-max = false
interval = 5
format-volume = <label-volume>
format-muted = <label-muted>

label-volume = %{T1}Ô©Ĺ%{T-} %{T2}%percentage%%%{T-}
label-volume-foreground = ${colors.color4}

label-muted = %{T1}ÔĪĚ%{T-} %{T2}muted!%{T-}
label-muted-foreground = ${colors.color6}

click-right = pavucontrol &

[module/battery_one]
type = internal/battery

full-at = 99
battery = BAT0
adapter = ADP1
poll-interval = 5
format-charging = <label-charging>
format-discharging = <label-discharging>

label-charging = %{T2}ÔĖÉ%{T-} %{T2}%percentage%%%{T-}
label-charging-foreground = ${colors.color2}

label-discharging = %{T1}ÔČĀ%{T-} %{T2}%percentage%%%{T-}
label-discharging-foreground = ${colors.color2}

label-full = %{T1}ÔČÄ%{T-} %{T2}Full!%{T-}
label-full-foreground = ${colors.color2}

[module/battery_two]
type = internal/battery

full-at = 99
battery = BAT1
adapter = ADP1
poll-interval = 5
format-charging = <label-charging>
format-discharging = <label-discharging>

label-charging = %{T2}ÔĖÉ%{T-} %{T2}%percentage%%%{T-}
label-charging-foreground = ${colors.color2}

label-discharging = %{T1}ÔČĀ%{T-} %{T2}%percentage%%%{T-}
label-discharging-foreground = ${colors.color2}

label-full = %{T1}ÔČÄ%{T-} %{T2}Full!%{T-}
label-full-foreground = ${colors.color2}

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
format-underline = #f50a4d
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.secondary}

ramp-0 = ÓÉČ
ramp-1 = ÓÉä
ramp-2 = ÓÉč
ramp-foreground = ${colors.foreground-alt}

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[module/powermenu]
type = custom/menu
content = "Ô§§"
click-left = ~/.config/rofi/powermenu.sh
content-background = ${colors.blue-darker}
content-foreground = ${colors.white}
content-padding = 1
margin-right = 0

[global/wm]
margin-top = 5
margin-bottom = 5

; vim:ft=dosini
