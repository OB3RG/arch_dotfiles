include-file = $HOME/.config/polybar/colors
include-file = $HOME/.config/polybar/module

[bar/laptop]
override-redirect = false
width = 100%
height = 29

fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = ${colors.white}

padding-left = 0
padding-right = 1

module-margin = 0

font-0 = Iosevka:weight=medium:pixelsize=8;2
font-1 = Iosevka:weight=medium:pixelsize=6;1
font-2 = Symbols Nerd Font:size=8

modules-left = powermenu sps keyboard sps backlight
modules-center = bspwm
modules-right = pulseaudio sps cpu sps memory sps temperature sps battery_one sps battery_two sps date

spacing = 0

dim-value = 1.0

wm-name = bspwm
wm-restack = bspwm

tray-position = right
tray-detached = false
tray-maxsize = 16
tray-padding = 2
tray-scale = 1

dpi-x = 133
dpi-y = 133

[settings]
screenchange-reload = true

[global/wm]
margin-top = 5
margin-bottom = 5

